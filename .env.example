# Personal Agent P0 — example environment file.
# Copy to `.env` and fill in real values. `.env` is .gitignored.
#
# Any variable whose NAME ends in TOKEN / SECRET / KEY / PASSWORD is
# treated as sensitive by the redactor (PRD §15 P0 redaction list).

# Telegram
TELEGRAM_BOT_TOKEN=
AUTHORIZED_TELEGRAM_USER_ID=

# Hetzner Object Storage (S3-compatible)
S3_ENDPOINT=
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Runtime
NODE_ENV=development

# Log level is configured in `config/runtime.json#log.level`,
# not via env. `LOG_LEVEL` is intentionally not consumed by the
# loader (`src/config.ts`).

# Optional: override the default config file path.
ACTWYN_CONFIG_PATH=config/runtime.json

# Optional: override default storage paths (default: /var/lib/actwyn/*)
# ACTWYN_DB_PATH=/var/lib/actwyn/actwyn.db
# ACTWYN_MIGRATIONS_PATH=/opt/actwyn/migrations
# ACTWYN_OBJECTS_PATH=/var/lib/actwyn/objects
# ACTWYN_MEMORY_PATH=/var/lib/actwyn/memory

# Optional: enable bootstrap whoami mode (DEC-009, 30-min expiry)
# BOOTSTRAP_WHOAMI=false
